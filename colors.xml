package com.markerboard;

import android.content.Context;
import android.graphics.Canvas;
import android.graphics.Paint;
import android.util.AttributeSet;
import android.view.View;

/**
 * Draws faint horizontal lines mimicking a whiteboard / ruled surface.
 * Very subtle — just enough texture to feel physical without being distracting.
 */
public class BoardSurfaceView extends View {

    private final Paint linePaint = new Paint(Paint.ANTI_ALIAS_FLAG);
    private final Paint shadowPaint = new Paint(Paint.ANTI_ALIAS_FLAG);

    public BoardSurfaceView(Context context) {
        super(context);
        init();
    }

    public BoardSurfaceView(Context context, AttributeSet attrs) {
        super(context, attrs);
        init();
    }

    public BoardSurfaceView(Context context, AttributeSet attrs, int defStyleAttr) {
        super(context, attrs, defStyleAttr);
        init();
    }

    private void init() {
        linePaint.setColor(0x12000000);  // very faint black
        linePaint.setStrokeWidth(1f);
        linePaint.setStyle(Paint.Style.STROKE);

        shadowPaint.setColor(0x08000000);
        shadowPaint.setStrokeWidth(2f);
        shadowPaint.setStyle(Paint.Style.STROKE);

        setWillNotDraw(false);
    }

    @Override
    protected void onDraw(Canvas canvas) {
        super.onDraw(canvas);
        float w = getWidth();
        float h = getHeight();
        float lineSpacing = 72f; // dp-ish spacing between ruled lines

        // Draw subtle horizontal rules
        for (float y = lineSpacing; y < h; y += lineSpacing) {
            canvas.drawLine(32f, y, w - 32f, y, linePaint);
        }

        // Very faint left margin line
        canvas.drawLine(80f, 0, 80f, h, shadowPaint);
    }
}
