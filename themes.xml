package com.markerboard;

import org.json.JSONArray;
import org.json.JSONObject;

import java.io.IOException;
import java.util.ArrayList;
import java.util.List;
import java.util.concurrent.TimeUnit;

import okhttp3.Call;
import okhttp3.Callback;
import okhttp3.OkHttpClient;
import okhttp3.Request;
import okhttp3.Response;

public class SheetFetcher {

    public interface FetchCallback {
        void onSuccess(List<RawRow> rows);
        void onError(String message);
    }

    public static class RawRow {
        public final int rowIndex;
        public final String taskText;
        public final boolean done;

        public RawRow(int rowIndex, String taskText, boolean done) {
            this.rowIndex = rowIndex;
            this.taskText = taskText;
            this.done     = done;
        }
    }

    private final OkHttpClient client;

    public SheetFetcher() {
        client = new OkHttpClient.Builder()
                .connectTimeout(10, TimeUnit.SECONDS)
                .readTimeout(15, TimeUnit.SECONDS)
                .build();
    }

    public void fetch(SheetConfig config, FetchCallback callback) {
        if (!config.isConfigured()) {
            callback.onError("Not configured");
            return;
        }

        String url = config.buildApiUrl();
        Request request = new Request.Builder().url(url).build();

        client.newCall(request).enqueue(new Callback() {
            @Override
            public void onFailure(Call call, IOException e) {
                callback.onError(e.getMessage());
            }

            @Override
            public void onResponse(Call call, Response response) throws IOException {
                if (!response.isSuccessful()) {
                    callback.onError("HTTP " + response.code());
                    return;
                }
                try {
                    String body = response.body().string();
                    List<RawRow> rows = parse(body, config);
                    callback.onSuccess(rows);
                } catch (Exception e) {
                    callback.onError("Parse error: " + e.getMessage());
                }
            }
        });
    }

    private List<RawRow> parse(String json, SheetConfig config) throws Exception {
        List<RawRow> result = new ArrayList<>();
        JSONObject root  = new JSONObject(json);

        if (!root.has("values")) {
            return result; // empty sheet
        }

        JSONArray values = root.getJSONArray("values");

        // Determine column indices from config letters (A=0, B=1, …)
        int taskColIdx = colLetterToIndex(config.taskCol);
        int doneColIdx = colLetterToIndex(config.doneCol);

        for (int i = 0; i < values.length(); i++) {
            JSONArray row = values.getJSONArray(i);

            // Skip header row (row 0) if it doesn't look like a task
            if (i == 0) {
                String firstCell = row.length() > taskColIdx ? row.getString(taskColIdx) : "";
                if (firstCell.equalsIgnoreCase("task") || firstCell.equalsIgnoreCase("notes")
                        || firstCell.equalsIgnoreCase("item") || firstCell.equalsIgnoreCase("description")) {
                    continue;
                }
            }

            String taskText = "";
            boolean done    = false;

            if (row.length() > taskColIdx) {
                taskText = row.getString(taskColIdx).trim();
            }
            if (row.length() > doneColIdx) {
                String doneVal = row.getString(doneColIdx).trim().toUpperCase();
                done = doneVal.equals("TRUE") || doneVal.equals("1") || doneVal.equals("YES") || doneVal.equals("✓");
            }

            if (!taskText.isEmpty()) {
                result.add(new RawRow(i, taskText, done));
            }
        }
        return result;
    }

    private static int colLetterToIndex(String col) {
        if (col == null || col.isEmpty()) return 0;
        col = col.toUpperCase().trim();
        int result = 0;
        for (char c : col.toCharArray()) {
            result = result * 26 + (c - 'A' + 1);
        }
        return result - 1;
    }
}
