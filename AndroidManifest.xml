<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/taskItemRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="@dimen/task_row_padding_v"
    android:paddingBottom="@dimen/task_row_padding_v">

    <!-- Task label -->
    <TextView
        android:id="@+id/taskText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/task_row_padding_h"
        android:paddingEnd="@dimen/task_row_padding_h"
        android:textSize="@dimen/task_text_size"
        android:lineSpacingMultiplier="1.2"
        android:textColor="@color/ink_black" />

    <!-- Strike-through overlay — drawn programmatically via StrikeThroughView -->
    <com.markerboard.StrikeThroughView
        android:id="@+id/strikeView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</FrameLayout>
